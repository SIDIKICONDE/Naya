prefix=../installed/arm64
exec_prefix=${prefix}
libdir=../installed/arm64/lib
includedir=../installed/arm64/include

Name: libavcodec
Description: FFmpeg codec library
Version: 61.19.101
Requires: 
Requires.private: libswresample >= 5.3.100, libavutil >= 59.39.100
Conflicts:
