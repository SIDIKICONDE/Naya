prefix=../installed/arm64
exec_prefix=${prefix}
libdir=../installed/arm64/lib
includedir=../installed/arm64/include

Name: libavformat
Description: FFmpeg container format library
Version: 61.7.100
Requires: 
Requires.private: libavcodec >= 61.19.101, libswresample >= 5.3.100, libavutil >= 59.39.100
Conflicts:
Libs: -L${libdir}  -lavformat 
Libs.private: -lm -lbz2 -lz -framework CoreFoundation -framework Security
Cflags: -I${includedir}
